# Neon PostgreSQL (usar pooler en serverless / Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Secreto para firmar sesiones JWT (generar: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-long-random-string

# URL pública de la app (para generar QR y OAuth)
NEXT_PUBLIC_APP_URL=https://sosme.com.ar

# Google Tag Manager (contenedor público, ej. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Contacto público
NEXT_PUBLIC_CONTACT_WHATSAPP=5491132939080
NEXT_PUBLIC_CONTACT_EMAIL=somososme@gmail.com
NEXT_PUBLIC_INSTAGRAM_HANDLE=sosme.ar
NEXT_PUBLIC_TIKTOK_HANDLE=sosme.ar

# Google OAuth (Google Cloud Console → APIs → Credentials → OAuth 2.0)
# Redirect URI autorizada: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Mismo Client ID (público) para mostrar el botón de Google en login/registro
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Opcional: webhook n8n/Make para alertas a la familia
ALERT_WEBHOOK_URL=

# Email transaccional (verificación de cuenta) vía Resend — https://resend.com/api-keys
# Sin RESEND_API_KEY, en desarrollo el código se loguea en consola (no se envía email).
RESEND_API_KEY=
# Remitente verificado en Resend. Debe usar un dominio verificado en producción.
EMAIL_FROM=SOSme <no-reply@sosme.com.ar>

# Web Push (generar con: node scripts/generate-vapid-keys.mjs)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:somososme@gmail.com

# Panel de administración: emails con acceso admin (separados por coma)
ADMIN_EMAILS=admin@ejemplo.com

# Contacto WhatsApp (solo dígitos, ej. 5491123456789) — pricing y pedido de más QR
NEXT_PUBLIC_CONTACT_WHATSAPP=
