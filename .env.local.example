# Neon PostgreSQL (usar pooler en serverless / Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Secreto para firmar sesiones JWT (generar: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-long-random-string

# URL pública de la app (para generar QR)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: webhook n8n/Make para alertas a la familia
ALERT_WEBHOOK_URL=

# Web Push (generar con: node scripts/generate-vapid-keys.mjs)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@ejemplo.com
